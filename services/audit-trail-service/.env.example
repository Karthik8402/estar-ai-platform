# ─── Database ──────────────────────────────────────
DATABASE_URL=postgresql://epharmic:password@localhost:5432/epharmic_db

# ─── JWT (deferred — not enforced yet) ─────────────
JWT_SECRET=dev-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=15

# ─── AI Provider ───────────────────────────────────
# Options: gemini (free/dev), openai (production)
AI_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key-here

# ─── Service ───────────────────────────────────────
SERVICE_NAME=audit-trail-service
SERVICE_VERSION=1.0.0
SERVICE_PORT=8001

# ─── Docker PostgreSQL ─────────────────────────────
# If using Docker: docker run -d --name epharmic-pg -e POSTGRES_DB=epharmic_db -e POSTGRES_USER=epharmic -e POSTGRES_PASSWORD=password -p 5432:5432 postgres:15
DB_PASSWORD=password
